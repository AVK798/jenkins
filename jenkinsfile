pipeline {

    agent any
    environment {
        Name="AVK"
        /*secret=credentials('ubuntu-ssh')*/
    }
    options {
        // Timeout counter starts AFTER agent is allocated
        timeout(time: 30, unit: 'SECONDS')
        disableConcurrentBuilds()
    }
    stages {
        stage('one') {
            steps{
                sh "echo ${Name}"
                
                sh "env"
            }
        }
        stage('two') {
            environment {
                Age=18
            }
            steps {
                sh "echo ${age}"
                /*sh "echo ${secret}"*/
            }
        }
    }
}